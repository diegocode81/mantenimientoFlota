generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EstadoVehiculo {
  OPERATIVO
  MANTENIMIENTO
}

enum TipoMantenimiento {
  CORRECTIVO
  PREVENTIVO
  PROACTIVO
}

model Vehiculo {
  id             String                  @id @default(cuid())
  itemOrigen     String?
  placa          String?                 @unique
  disco          String?
  marca          String?
  tipo           String
  ano            Int?
  anoOriginal    String?
  cia            String?
  mantenimientos MantenimientoVehiculo[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([itemOrigen])
  @@index([marca])
  @@index([cia])
}

model MantenimientoVehiculo {
  id                  String            @id @default(cuid())
  vehiculoId          String
  fechaMantenimiento  DateTime
  estado              EstadoVehiculo
  kilometrajeOdometro Int               @default(0)
  tipoMantenimiento   TipoMantenimiento?
  rutaUbicacion       String
  tecnicosDesignados  String
  observaciones       String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  vehiculo            Vehiculo          @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)

  @@index([vehiculoId])
  @@index([estado])
  @@index([tipoMantenimiento])
  @@index([fechaMantenimiento])
}
