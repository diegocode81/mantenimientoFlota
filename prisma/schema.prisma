generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EstadoVehiculo {
  OPERATIVO
  MANTENIMIENTO
}

model Vehiculo {
  id             String                  @id @default(cuid())
  placa          String                  @unique
  disco          String
  marca          String
  tipo           String
  ano            Int
  cia            String
  mantenimientos MantenimientoVehiculo[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([marca])
  @@index([cia])
}

model MantenimientoVehiculo {
  id                 String         @id @default(cuid())
  vehiculoId         String
  fechaMantenimiento DateTime
  estado             EstadoVehiculo
  rutaUbicacion      String
  tecnicosDesignados String
  observaciones      String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  vehiculo           Vehiculo       @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)

  @@index([vehiculoId])
  @@index([estado])
  @@index([fechaMantenimiento])
}
